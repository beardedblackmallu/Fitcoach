<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash background — solid teal fill used as the legacy android:background
    fallback. The windowSplashScreenBackground attribute in styles.xml is the
    primary path on Android 12+; this drawable covers older API levels.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/splash_background" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:width="108dp"
        android:height="108dp"
        android:drawable="@drawable/ic_fitcoach_splash_icon" />
</layer-list>
